# ============================================
# Quanto Vale — Environment Variables
# ============================================

# App
APP_NAME=QuantoVale
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
APP_SECRET_KEY=change-me-to-a-random-secret-key-64-chars

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/quantovale
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/quantovale

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-to-a-random-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# SMTP Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=quantovalehoje@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=Quanto Vale
SMTP_FROM_EMAIL=quantovalehoje@gmail.com

# DeepSeek API
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_API_URL=https://api.deepseek.com/v1

# Storage
REPORTS_DIR=./storage/reports
UPLOADS_DIR=./storage/uploads

# Payments (future)
PAYMENT_WEBHOOK_SECRET=your-webhook-secret
